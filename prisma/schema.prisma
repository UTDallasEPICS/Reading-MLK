generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  emailVerified       Boolean              @default(false)
  role                String               @default("reader")
  raffleOptIn         Boolean              @default(true)
  publicityConsent    Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  admin               Boolean              @default(false)
  sessions            Session[]
  accounts            Account[]
  students            Student[]
  pendingEmailChanges PendingEmailChange?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @unique
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Poster {
  id          String      @id @default(uuid())
  tag         String      @default("other") //enum: "teacher", "personal", "studygroup", "other"
  verified    Boolean     @default(false)
  school      String?           
  district    String?
  zipcode     String?

  Classes       Class[]
  announcements Announcement[]
  @@index([tag])
  @@index([verified])
  @@index([school])
  @@index([district])
  @@index([zipcode])
}

model Student {
  id           Int    @id @default(autoincrement())
  name         String
  settings     Json?
  exp          Int    @default(0)
  parentUserId String

  Parent                User       @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  Classes               Class[]
  Submissions           FormSubmission[]
  WinnerOf              FormGroup[]   @relation("RaffleWinner")
  unlockedShopItems     ShopItem[]
  @@index([parentUserId])
}

model Class {
  id              String    @id @default(uuid())
  joinToken       String    @unique @default(uuid())
  name            String

  Students        Student[]
  Posters         Poster[]
  Announcements   Announcement[]
  FormGroups      FormGroup[]
}

model Announcement {
  id          Int     @id @default(autoincrement())
  postDate    DateTime
  expiryDate  DateTime?
  content     Json?
  author      String
  class       String

  Author      Poster    @relation(fields: [author], references: [id], onDelete: Cascade)
  Class       Class     @relation(fields: [class], references: [id], onDelete: Cascade)
  @@index([postDate])
  @@index([expiryDate])
}

model FormGroup {
  id           Int       @id @default(autoincrement())
  startDate    DateTime
  endDate      DateTime?
  class        String
  raffleWinner Int? // References the id of the Student who won the raffle for this form group

  Class        Class    @relation(fields: [class], references: [id], onDelete: Cascade)
  RaffleWinner Student? @relation(name: "RaffleWinner", fields: [raffleWinner], references: [id], onDelete: SetNull)
  Forms        Form[]
  @@index([class])
  @@index([startDate])
  @@index([endDate])
}

model Form {
  id                    Int       @id @default(autoincrement())
  order                 Int       @default(0)
  startDate             DateTime
  endDate               DateTime?
  published             Boolean   @default(false)
  formGroup             Int
  title                 String

  FormGroup   FormGroup        @relation(fields: [formGroup], references: [id], onDelete: Cascade)
  Submissions FormSubmission[]
  Components  FormComponent[]
  @@index([formGroup])
}

model FormComponent {
  id              Int    @id @default(autoincrement())
  form            Int
  order           Int    @default(0)
  questionType    String
  questionText    String
  questionOptions Json?

  Form      Form                 @relation(fields: [form], references: [id], onDelete: Cascade)
  Responses SubmissionResponse[]
}

model FormSubmission {
  id             Int      @id @default(autoincrement())
  student        Int
  form           Int
  submissionDate DateTime @default(now())

  Student         Student     @relation(fields: [student], references: [id], onDelete: Cascade)
  Form            Form        @relation(fields: [form], references: [id], onDelete: Cascade)
  Responses       SubmissionResponse[]

  @@unique([student, form])
  @@index([submissionDate])
}

model SubmissionResponse {
  id            Int    @id @default(autoincrement())
  submission    Int
  formComponent Int
  response      String

  FormSubmission FormSubmission @relation(fields: [submission], references: [id], onDelete: Cascade)
  FormComponent  FormComponent  @relation(fields: [formComponent], references: [id], onDelete: Cascade)
  @@index(formComponent)
  @@index(submission)
}

model ShopItem {
  id              Int     @id @default(autoincrement()) 
  type            String
  name            String
  dateAvailable   DateTime
  cost            Int     @default(0)

  Theme           ShopTheme?
  Animation       ShopAnimation?
  unlockedByStudents Student[]
}

model ShopTheme {
  id          Int    @id @default(autoincrement())
  shopItem    Int    @unique
  themeColor  String
  themeEffect Json?

  ShopItem ShopItem @relation(fields: [shopItem], references: [id], onDelete: Cascade)
}

model ShopAnimation {
  id              Int    @id @default(autoincrement())
  shopItem        Int    @unique
  animationType   String
  animationEffect Json?

  ShopItem ShopItem @relation(fields: [shopItem], references: [id], onDelete: Cascade)
}

model PendingEmailChange {
  id        String   @id @default(cuid())
  userId    String   @unique
  newEmail  String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([expiresAt])
}
